# IGDB (Twitch OAuth) - https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=your_twitch_client_id_here
IGDB_CLIENT_SECRET=your_twitch_client_secret_here

# Steam API - https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here
STEAM_ACCOUNT_ID=your_steam_account_id_here

# RAWG API - https://rawg.io/apidocs
RAWG_API_KEY=your_rawg_api_key_here

# Optional: Override database path (defaults to ./data/gamelog.db)
# DB_PATH=/custom/path/to/gamelog.db

# Optional: Override server port (defaults to 3000)
# PORT=3000
